# =============================================================================
# SEOWebAgency - Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values before running locally.
# =============================================================================

# Formspree endpoint for contact form email forwarding
# 1. Go to https://formspree.io and create an account
# 2. Create a new form pointing to seowebagency.in@gmail.com
# 3. Replace the URL below with your Formspree form endpoint
# Format: https://formspree.io/f/xxxxxx
FORMSPREE_URL=https://formspree.io/f/YOUR_FORM_ID_HERE
